# Whisper Configuration for Live Transcription
# Model size: larger models are more accurate but slower
# Options: tiny, base, small, medium, large-v2, large-v3, large-v3-turbo
WHISPER_MODEL=large-v3-turbo

# Device to run model on
# Options: cpu, cuda (requires NVIDIA GPU)
DEVICE=cpu

# Compute type affects speed and memory usage
# Options: int8, float16, float32
# int8 is fastest and uses least memory (recommended for cpu)
# float16 requires CUDA (recommended for GPU)
COMPUTE_TYPE=int8

# Output directory for transcript and audio files
# Transcripts: transcripts/transcript_YYYY-MM-DD_HH-MM-SS.txt
# Recordings: transcripts/recording_YYYY-MM-DD_HH-MM-SS.wav
OUTPUT_DIR=transcripts

# AWS Bedrock Configuration for Meeting Summarization
# Credentials: Use ~/.aws/credentials or AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY env vars
AWS_REGION=us-east-1

# Bedrock Model ID for summarization
# Use global cross-region inference profile for Claude Sonnet 4.5
# Options:
#   global.anthropic.claude-sonnet-4-5-20250929-v1:0 (latest, best quality)
#   anthropic.claude-3-5-sonnet-20241022-v2:0 (balanced)
#   anthropic.claude-3-haiku-20240307-v1:0 (fast, cheap)
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0

# Auto-summarization after transcription
AUTO_SUMMARIZE=true

# Web Server Configuration
WEB_HOST=127.0.0.1
WEB_PORT=8000

# Zoom Bot Integration (Docker-based Meeting SDK)
# URL to connect to the Zoom bot's command server
ZOOM_BOT_URL=ws://localhost:3001

# Playwright Zoom Bot Configuration (Web Client)
# Meeting URL to join (full URL including meeting ID)
ZOOM_MEETING_URL=

# Bot display name shown in participant list
ZOOM_BOT_NAME=Transcription Bot

# Meeting password (if required)
ZOOM_MEETING_PASSWORD=

# Target breakout room name (for breakout room support)
ZOOM_BREAKOUT_ROOM=

# Browser settings
# Run browser in headless mode (true/false)
PLAYWRIGHT_HEADLESS=true
# Default timeout in milliseconds
PLAYWRIGHT_TIMEOUT=60000
# Slow down browser actions by X ms (for debugging)
PLAYWRIGHT_SLOWMO=0

# Debugging
# Enable verbose logging
PLAYWRIGHT_DEBUG=false
# Take screenshots on errors
PLAYWRIGHT_SCREENSHOTS=true
