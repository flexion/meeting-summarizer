# Whisper Configuration for Live Transcription
# Model size: larger models are more accurate but slower
# Options: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=base

# Device to run model on
# Options: cpu, cuda (requires NVIDIA GPU)
DEVICE=cpu

# Compute type affects speed and memory usage
# Options: int8, float16, float32
# int8 is fastest and uses least memory (recommended for cpu)
# float16 requires CUDA (recommended for GPU)
COMPUTE_TYPE=int8

# Audio buffer duration in seconds (affects latency vs accuracy)
# Smaller values = lower latency, larger values = better accuracy
CHUNK_DURATION=60

# Output directory for transcript files
# Transcripts are saved as: transcripts/transcript_YYYY-MM-DD_HH-MM-SS.txt
OUTPUT_DIR=transcripts

# AWS Bedrock Configuration for Meeting Summarization
# Credentials: Use ~/.aws/credentials or AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY env vars
AWS_REGION=us-east-1

# Bedrock Model ID for summarization
# Use global cross-region inference profile for Claude Sonnet 4.5
# Options:
#   global.anthropic.claude-sonnet-4-5-20250929-v1:0 (latest, best quality)
#   anthropic.claude-3-5-sonnet-20241022-v2:0 (balanced)
#   anthropic.claude-3-haiku-20240307-v1:0 (fast, cheap)
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0

# Web Server Configuration
WEB_HOST=127.0.0.1
WEB_PORT=8000
