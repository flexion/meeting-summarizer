# Zoom SDK Credentials
# Get these from https://marketplace.zoom.us/ by creating an SDK App
ZOOM_CLIENT_ID=your_client_id
ZOOM_CLIENT_SECRET=your_client_secret

# Bot Settings
BOT_DISPLAY_NAME=Transcription Bot

# WebSocket URL for audio streaming to transcriber
# Use host.docker.internal to reach the host machine from Docker
TRANSCRIBER_WS_URL=ws://host.docker.internal:8000/zoom-audio

# Audio streaming port (inside container)
AUDIO_WS_PORT=3001
